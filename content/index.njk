        <h3>Maintenance and Support</h3>
        <p>Regular updates, security patches, and backups - plus someone to call when something breaks. Available as ad-hoc support or an ongoing retainer.</p>
      </div>      
    </div>
  </div>
</section>
<section class="portfolio" id="portfolio">
  <div class="container">
    <div class="section-title">
        <h2>Latest work</h2>
        <a href="/work" name="View more of my work" aria-label="View more of my work">View more</a>
    </div>    
    <div class="portfolio-grid">
        {% for item in portfolio | limit(3) %}
            <div class="portfolio-item">
                <img src="{{ item.images.desktop }}" alt="{{ item.title }}">
                <div class="portfolio-details">
                    <h3>{{ item.title }}</h3>
                    <p>{{ item.description }}</p>
                    <a href="{{ item.url }}" name="Visit the website of {{ item.title }}" aria-label="Visit the website of {{ item.title }}" target="_blank">{{ item.url }}</a>
                    <p class="tags">{{ item.tags | join(" - ") }}</p>            
                </div>
            </div>
        {% endfor %}
    </div>
  </div>
</section>

<section class="contact" id="contact">
  <div class="container">
    <div class="section-title flex-column flex-center">
        <h2>Get in touch</h2>
        <p>Have a project in mind or need help with an existing site? Send me a message and I'll get back to you promptly.</p>
    </div>       
    <form 
      class="contact-form" 
      name="contact" 
      method="POST" 
      action="/thankyou/" 
      netlify-honeypot="bot-field" 
      netlify>
      <p class="hidden">
        <label>Don't fill this out if you're human: <input name="bot-field" type="text" /></label>
      </p>      
      <div class="field-row">
        <div class="field">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required>
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required>
        </div>
      </div>
      <div class="field">
        <label for="service">Service</label>
        <select id="service" name="service">
          <option value="" placeholder>Select…</option>
          <option value="wordpress">WordPress</option>
          <option value="shopify">Shopify</option>
          <option value="static">Static Website</option>
          <option value="design">Design</option>
          <option value="hosting">Hosting</option>
          <option value="support">Maintenance and Support</option>          
          <option value="other">Not sure yet / Need assistance</option>
        </select>
      </div>
      <div class="field">
        <label for="message">Message</label>
        <textarea id="message" name="message" required></textarea>
      </div>
      <button type="submit" class="btn btn-filled" id="submit-btn">Send message</button>
    </form>
  </div>
</section>